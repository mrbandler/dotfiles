#!/usr/bin/env bash

args=("$@")

if ! command -v "cht.sh" &> /dev/null; then
    curl -s https://cht.sh/:cht.sh > "$HOME/.local/bin/cht.sh"
    chmod +x "$HOME/.local/bin/cht.sh"
fi

if [[ ${#args[@]} -eq 0 ]] ||
   [[ ${args[*]} =~ "--shell" ]] ||
   [[ ${args[*]} =~ "--help" ]] ||
   [[ ${args[*]} =~ "--mode" ]]; then
    cht.sh $@
else
    filename="cht.sh $@"
    cht.sh $@ | bat --file-name "$filename"
fi
